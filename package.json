{
  "name": "plot-your-path-frontend",
  "version": "0.4.1",
  "packageManager": "pnpm@10.32.1",
  "private": true,
  "scripts": {
    "build": "next build",
    "build:pages": "node scripts/generate-app-metadata.mjs && cross-env PYP_STATIC_EXPORT=true PYP_PAGES_ENABLE_REPO_PATH=false next build",
    "dev": "next dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "start": "next start",
    "test": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@evergraytech/ai-config": "^0.2.1",
    "@evergraytech/design-system": "^0.2.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "cross-env": "^7.0.3",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
